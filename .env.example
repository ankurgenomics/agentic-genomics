# Anthropic / Claude (primary LLM provider)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI (for provider-agnostic support)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: LangSmith tracing (highly recommended for agent debugging)
# LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=agentic-genomics

# Agent behaviour
AG_LOG_LEVEL=INFO
AG_CACHE_DIR=.agentic_genomics_cache
AG_DEFAULT_MODEL=claude-sonnet-4-5
